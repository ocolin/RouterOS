{
    "name": "ocolin/routeros",
    "description": "Client for RouterOS API",
    "type": "library",
    "keywords": ["mikrotik", "routeros", "api", "network"],
    "homepage": "https://github.com/ocolin/routeros",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.4",
        "ocolin/global-type": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1",
        "ocolin/easyenv": "^3.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ocolin\\RouterOS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ocolin\\RouterOS\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Colin Miller",
            "email": "ocolin@cruzio.com"
        }
    ],
    "suggest": {
        "illuminate/support": "Required for Laravel integration (^10.0|^11.0)"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ocolin\\RouterOS\\Laravel\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "debug": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices --debug",
        "integration": "vendor/bin/phpunit --no-coverage --group integration",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
